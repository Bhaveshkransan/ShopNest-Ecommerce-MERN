{
  "name": "shopnest-full-stack",
  "version": "1.0.0",
  "description": "",
  "keywords": [
    "bhavesh",
    "microservices"
  ],
  "license": "ISC",
  "author": "Bhavesh G.",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "install-all": "cd backend && npm install --legacy-peer-deps && cd ../frontend && npm install --legacy-peer-deps --production=false",
    "dev:server": "cd backend && npm run dev",
    "dev:client": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm start",
    "seed": "npm --prefix backend run seed"
  },
  "dependencies": {
    "concurrently": "^10.0.3"
  }
}

  